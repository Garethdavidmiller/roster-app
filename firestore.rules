rules_version = '2';
// MYB Roster — Firestore Security Rules
// Deploy: firebase deploy --only firestore:rules
// Or via Firebase Console → Firestore → Rules tab.
//
// ⚠️  DEPLOYMENT ORDER — READ BEFORE DEPLOYING ⚠️
//
// These rules require Firebase Auth (request.auth != null) for all writes.
// Deploy them ONLY AFTER running setupRosterAuth to create all staff accounts:
//
//   curl -X POST \
//     -H "Authorization: Bearer <ROSTER_SECRET>" \
//     https://europe-west2-myb-roster.cloudfunctions.net/setupRosterAuth
//
// Until accounts exist, writes will fail. Once setupRosterAuth confirms all
// accounts are created (check "created" + "skipped" arrays in the response),
// deploy these rules: firebase deploy --only firestore:rules
//
// Last updated: v7.61 — added request.auth != null for all writes and deletes.

service cloud.firestore {
  match /databases/{database}/documents {

    match /overrides/{document=**} {
      allow read;
      allow create, update: if
        request.auth != null &&
        request.resource.data.keys().hasAll(['date', 'memberName', 'type', 'value', 'note']) &&
        request.resource.data.date is string &&
        request.resource.data.date.size() == 10 &&
        request.resource.data.type in [
          'spare_shift', 'shift', 'allocated', 'overtime', 'rdw', 'swap',
          'annual_leave', 'correction', 'sick'
        ] &&
        request.resource.data.value is string &&
        request.resource.data.value.size() > 0;
      allow delete: if request.auth != null;
    }

    match /memberSettings/{document=**} {
      allow read;
      allow create, update: if
        request.auth != null &&
        request.resource.data.keys().hasAll(['memberName', 'faithCalendar']) &&
        request.resource.data.memberName is string &&
        request.resource.data.faithCalendar in [
          'islamic', 'hindu', 'chinese', 'jamaican',
          'congolese', 'portuguese', 'none'
        ];
      allow delete: if request.auth != null;
    }

    match /huddles/{date} {
      allow read;
      // Cloud Function writes use Admin SDK — bypasses these rules entirely.
      // Browser writes (manual admin upload) require auth.
      allow create, update: if
        request.auth != null &&
        request.resource.data.keys().hasAll(['date', 'storageUrl', 'uploadedAt', 'uploadedBy']) &&
        request.resource.data.date is string &&
        request.resource.data.storageUrl is string;
      allow delete: if request.auth != null;
    }

    match /pushSubscriptions/{docId} {
      // Push subscriptions are written by the browser using the Web Push API.
      // Authentication is by subscription endpoint (derived key) — any authenticated
      // user may manage their own subscription.
      allow read, write: if request.auth != null;
    }

  }
}
