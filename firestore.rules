rules_version = '2';
// MYB Roster — Firestore Security Rules
//
// ⚠️  DEPLOYMENT ORDER — READ BEFORE DEPLOYING ⚠️
//
// These rules require Firebase Auth (request.auth != null) for all writes.
// Deploy ONLY AFTER running the "Set up accounts" button in admin.html
// (Admin section → Staff Login Accounts). All staff must have Firebase Auth
// accounts before the rules go live — otherwise every Firestore write fails.
//
// Once the button reports no failures:
//   GitHub → Actions → "Deploy Firestore Rules" → Run workflow
//
// The workflow (deploy-rules.yml) also runs automatically whenever this
// file changes on the main branch.
//
// Last updated: v7.94 — rules deployed and active. Auth migration complete.

service cloud.firestore {
  match /databases/{database}/documents {

    match /overrides/{document=**} {
      allow read;
      allow create, update: if
        request.auth != null &&
        request.resource.data.keys().hasAll(['date', 'memberName', 'type', 'value', 'note']) &&
        request.resource.data.date is string &&
        request.resource.data.date.size() == 10 &&
        request.resource.data.type in [
          'spare_shift', 'shift', 'allocated', 'overtime', 'rdw', 'swap',
          'annual_leave', 'correction', 'sick'
        ] &&
        request.resource.data.value is string &&
        request.resource.data.value.size() > 0;
      allow delete: if request.auth != null;
    }

    match /memberSettings/{document=**} {
      allow read;
      allow create, update: if
        request.auth != null &&
        request.resource.data.keys().hasAll(['memberName', 'faithCalendar']) &&
        request.resource.data.memberName is string &&
        request.resource.data.faithCalendar in [
          'islamic', 'hindu', 'chinese', 'jamaican',
          'congolese', 'portuguese', 'none'
        ];
      allow delete: if request.auth != null;
    }

    match /huddles/{date} {
      allow read;
      // Cloud Function writes use Admin SDK — bypasses these rules entirely.
      // Browser writes (manual admin upload) require auth.
      allow create, update: if
        request.auth != null &&
        request.resource.data.keys().hasAll(['date', 'storageUrl', 'uploadedAt', 'uploadedBy']) &&
        request.resource.data.date is string &&
        request.resource.data.storageUrl is string;
      allow delete: if request.auth != null;
    }

    match /pushSubscriptions/{docId} {
      // Push subscriptions are written from index.html which is a public page
      // (no login required). The data stored is a browser endpoint URL and
      // encryption keys — not PII. Writes are open so any device can subscribe
      // or unsubscribe without needing a Firebase Auth session.
      allow read: if request.auth != null;
      allow write: if true;
    }

  }
}
