rules_version = '2';
// MYB Roster — Firestore Security Rules
// Deploy: firebase deploy --only firestore:rules
// Or via Firebase Console → Firestore → Rules tab.
//
// Last updated: v6.44 — added 'shift' type to overrides allow list.
// Legacy types (overtime/swap/allocated) retained so existing records still display correctly.

service cloud.firestore {
  match /databases/{database}/documents {

    match /overrides/{document=**} {
      allow read;
      allow create, update: if
        request.resource.data.keys().hasAll(['date', 'memberName', 'type', 'value', 'note']) &&
        request.resource.data.date is string &&
        request.resource.data.date.size() == 10 &&
        request.resource.data.type in [
          'spare_shift', 'shift', 'allocated', 'overtime', 'rdw', 'swap',
          'annual_leave', 'correction', 'sick'
        ] &&
        request.resource.data.value is string &&
        request.resource.data.value.size() > 0;
      allow delete;
    }

    match /memberSettings/{document=**} {
      allow read;
      allow create, update: if
        request.resource.data.keys().hasAll(['memberName', 'faithCalendar']) &&
        request.resource.data.memberName is string &&
        request.resource.data.faithCalendar in [
          'islamic', 'hindu', 'chinese', 'jamaican',
          'congolese', 'portuguese', 'none'
        ];
      allow delete;
    }

    match /huddles/{date} {
      allow read;
      allow create, update: if
        request.resource.data.keys().hasAll(['date', 'storageUrl', 'uploadedAt', 'uploadedBy']) &&
        request.resource.data.date is string &&
        request.resource.data.storageUrl is string;
      allow delete;
    }

    match /pushSubscriptions/{docId} {
      allow read, write: if true;
    }

  }
}
